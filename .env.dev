SPRING_PROFILES_ACTIVE=dev

GATEWAY_HOST_PORT=8060
FRONTEND_HOST_PORT=3000
CLASSIFIER_HOST_PORT=8011
RAGBOT_HOST_PORT=5000

# llama-cpp-python (replaces Ollama).
# Place your GGUF file in ragbot/models/ and set the filename here.
LLAMA_MODEL_FILE=Meta-Llama-3-8B-Instruct-Q4_K_M.gguf
# Layers to offload to the GRID T4-16Q GPU (33 = all layers for Llama-3-8B).
LLAMA_N_GPU_LAYERS=33
LLAMA_N_CTX=8192

NEXT_PUBLIC_API_GATEWAY=http://localhost:8060
NEXT_PUBLIC_RAGBOT_API=http://localhost:5000
NEXT_PUBLIC_CLASSIFIER_API=http://localhost:8011

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000